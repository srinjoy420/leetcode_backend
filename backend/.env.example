PORT=5000
DATABASE_URL=
NODE_ENV=development
JWT_SECRET=

# Frontend URL (Netlify). Required in production for CORS + cookies.
# Example: https://your-app.netlify.app
CLIENT_URL=http://localhost:5173

# From https://console.cloudinary.com/ → Dashboard
# Use the ROOT API Key + API Secret (or a custom key with "Upload" permission enabled).
# Restricted keys without Upload cause 403 errors on profile picture upload.
CLOUDNARY_CLOUD_NAME=
CLOUDNARY_API_KEY=
CLOUDNARY_API_SECRET=
