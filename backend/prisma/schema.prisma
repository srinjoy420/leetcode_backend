generator client {
  provider = "prisma-client-js"
  
  
}

datasource db {
  provider = "postgresql"
}
model Test{
  id String @id @default(cuid())
  title String
}


enum UserRole {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  role      UserRole @default(USER)
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  problems Problem[]

  @@index([role])
}
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem{
  id          String     @id @default(uuid())
  title       String
  description String
  difficulty  Difficulty
  tags        String[] //["tag1",tag2]
  userId      String
  examples    Json
  constraints String
  hints       String?
  editorial   String?

  testCases          Json
  codeSnippets        Json //which language
  referenceSolutions  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([difficulty])

}

